Read Just Perfection startup-status gsetting before the startup animation
begins, and restore hasOverview after startup-complete so overview
shortcuts (Super+1/2/3) still work later.

--- a/js/ui/layout.js
+++ b/js/ui/layout.js
@@ -998,6 +998,21 @@
     async _prepareStartupAnimation() {
         await this._ensurePrimaryMonitor();
 
+        if (!Main.sessionMode.isGreeter) {
+            const schemaSource = Gio.SettingsSchemaSource.get_default();
+            const schema = schemaSource.lookup(
+                'org.gnome.shell.extensions.just-perfection',
+                true);
+            if (schema) {
+                const settings = new Gio.Settings({settings_schema: schema});
+                if (settings.get_int('startup-status') === 0) {
+                    Main.sessionMode.hasOverview = false;
+                    this.connect('startup-complete', () =>
+                        setTimeout(() => Main.sessionMode.hasOverview = true, 0));
+                }
+            }
+        }
+
         // During the initial transition, add a simple actor to block all events,
         // so they don't get delivered to X11 windows that have been transformed.
         this._coverPane = new Clutter.Actor({
