 static void
+on_parent_clicked (GtkGestureClick *gesture,
+                   int              n_press,
+                   double           x,
+                   double           y,
+                   gpointer         user_data)
+{
+    NautilusRenameFilePopover *self = NAUTILUS_RENAME_FILE_POPOVER (user_data);
+    graphene_rect_t popover_rect;
+
+    if (!gtk_widget_get_mapped (GTK_WIDGET (self)))
+    {
+        return;
+    }
+
+    if (gtk_widget_compute_bounds (GTK_WIDGET (self),
+                                   gtk_widget_get_parent (GTK_WIDGET (self)),
+                                   &popover_rect))
+    {
+        if (x < popover_rect.origin.x ||
+            x > popover_rect.origin.x + popover_rect.size.width ||
+            y < popover_rect.origin.y ||
+            y > popover_rect.origin.y + popover_rect.size.height)
+        {
+            reset_state (self);
+        }
+    }
+}
