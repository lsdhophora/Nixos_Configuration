+static void cb_print_status_changed(GtkPrintOperation* print_operation, zathura_t* zathura) {
+  if (zathura_has_document(zathura) == false || zathura->ui.session == NULL) {
+    return;
+  }
+
+  GtkPrintStatus status = gtk_print_operation_get_status(print_operation);
+  if (status == GTK_PRINT_STATUS_ERROR) {
+    const char* status_string = gtk_print_operation_get_status_string(print_operation);
+    if (status_string != NULL && strlen(status_string) > 0) {
+      girara_notify(zathura->ui.session, GIRARA_ERROR, "%s", status_string);
+    }
+  }
+}
