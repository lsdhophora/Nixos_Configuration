diff --git a/zathura/print.c b/zathura/print.c
index 2cd8fe7d..da6b0485 100644
--- a/zathura/print.c
+++ b/zathura/print.c
@@ -9,6 +9,99 @@
 #include <girara-gtk/statusbar.h>
 #include <girara-gtk/session.h>
 #include <glib/gi18n.h>
+#include <string.h>
+
+static void cb_print_status_changed(GtkPrintOperation* print_operation, gpointer user_data);
+static gboolean cb_print_status_timeout(gpointer user_data);
+
+void zathura_print_cleanup(zathura_t* zathura) {
+  if (zathura != NULL) {
+    if (zathura->print.status_timeout_id > 0) {
+      g_source_remove(zathura->print.status_timeout_id);
+      zathura->print.status_timeout_id = 0;
+    }
+    if (zathura->print.operation != NULL) {
+      g_signal_handlers_disconnect_by_data(zathura->print.operation, zathura);
+      g_clear_object(&zathura->print.operation);
+    }
+  }
+}
+
+void zathura_print_cancel(zathura_t* zathura) {
+  if (zathura == NULL || zathura->print.operation == NULL) {
+    return;
+  }
+
+  gtk_print_operation_cancel(zathura->print.operation);
+  if (zathura->ui.session != NULL) {
+    girara_notify(zathura->ui.session, GIRARA_WARNING, _("Printing cancelled."));
+  }
+  zathura_print_cleanup(zathura);
+}
+
+static void check_print_status(zathura_t* zathura) {
+  if (zathura == NULL || zathura->print.operation == NULL || zathura->ui.session == NULL) {
+    return;
+  }
+
+  GtkPrintStatus status = gtk_print_operation_get_status(zathura->print.operation);
+  const char* status_string = gtk_print_operation_get_status_string(zathura->print.operation);
+
+  girara_debug("Print status check: status=%d, status_string=%s",
+               status, status_string ? status_string : "(null)");
+
+  switch (status) {
+    case GTK_PRINT_STATUS_FINISHED:
+      girara_notify(zathura->ui.session, GIRARA_INFO, _("Print job completed successfully."));
+      zathura_print_cleanup(zathura);
+      break;
+    case GTK_PRINT_STATUS_FINISHED_ABORTED:
+      if (status_string != NULL && strlen(status_string) > 0) {
+        girara_notify(zathura->ui.session, GIRARA_ERROR, "%s", status_string);
+      } else {
+        girara_notify(zathura->ui.session, GIRARA_ERROR, _("Printing was aborted."));
+      }
+      zathura_print_cleanup(zathura);
+      break;
+    case GTK_PRINT_STATUS_PENDING_ISSUE:
+      if (status_string != NULL && strlen(status_string) > 0) {
+        girara_notify(zathura->ui.session, GIRARA_ERROR, _("Printing error: %s"), status_string);
+      } else {
+        girara_notify(zathura->ui.session, GIRARA_ERROR, _("Printing encountered an issue."));
+      }
+      zathura_print_cleanup(zathura);
+      break;
+    default:
+      break;
+  }
+}
+
+static void cb_print_status_changed(GtkPrintOperation* UNUSED(print_operation), gpointer user_data) {
+  zathura_t* zathura = (zathura_t*)user_data;
+  check_print_status(zathura);
+}
+
+static gboolean cb_print_status_timeout(gpointer user_data) {
+  zathura_t* zathura = (zathura_t*)user_data;
+  if (zathura == NULL || zathura->print.operation == NULL) {
+    return G_SOURCE_REMOVE;
+  }
+
+  check_print_status(zathura);
+
+  if (zathura->print.operation == NULL) {
+    return G_SOURCE_REMOVE;
+  }
+
+  GtkPrintStatus status = gtk_print_operation_get_status(zathura->print.operation);
+  if (status == GTK_PRINT_STATUS_FINISHED ||
+      status == GTK_PRINT_STATUS_FINISHED_ABORTED ||
+      status == GTK_PRINT_STATUS_PENDING_ISSUE) {
+    return G_SOURCE_REMOVE;
+  }
+
+  return G_SOURCE_CONTINUE;
+}
 
