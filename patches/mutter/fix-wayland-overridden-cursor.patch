From bb9728d3399007690a74abeb9eefa7c07dcbaa1e Mon Sep 17 00:00:00 2001
From: Alessandro Astone <alessandro.astone@canonical.com>
Date: Tue, 14 Apr 2026 11:00:29 +0200
Subject: [PATCH 2/4] clutter/sprite: Use overridden global cursor in
 invalidate_cursor

Do not rely on the global cursor override being stored in the actors.
This will become the main place where we change the cursor to the global
override.
---
 clutter/clutter/clutter-sprite.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/clutter/clutter/clutter-sprite.c b/clutter/clutter/clutter-sprite.c
index e45d47375e0..0d19790a8c1 100644
--- a/clutter/clutter/clutter-sprite.c
+++ b/clutter/clutter/clutter-sprite.c
@@ -27,6 +27,7 @@
 
 #include "clutter/clutter-action-private.h"
 #include "clutter/clutter-actor-private.h"
+#include "clutter/clutter-backend-private.h"
 #include "clutter/clutter-debug.h"
 #include "clutter/clutter-enum-types.h"
 #include "clutter/clutter-event-private.h"
@@ -1193,12 +1194,21 @@ clutter_sprite_invalidate_cursor (ClutterSprite *sprite)
   ClutterContext *context = clutter_actor_get_context (CLUTTER_ACTOR (stage));
   ClutterBackend *backend = clutter_context_get_backend (context);
   ClutterSeat *seat = clutter_backend_get_default_seat (backend);
+  ClutterCursorType global_cursor;
   g_autoptr (ClutterCursor) cursor = NULL;
 
   if (clutter_sprite_get_role (sprite) == CLUTTER_SPRITE_ROLE_POINTER &&
       !clutter_seat_is_unfocus_inhibited (seat))
     goto out;
 
+  /* If there's a global cursor override, short circuit and use that */
+  global_cursor = clutter_backend_get_global_cursor_type (backend);
+  if (global_cursor != CLUTTER_CURSOR_INHERIT)
+    {
+      cursor = clutter_backend_get_cursor (backend, global_cursor);
+      goto out;
+    }
+
   /* If there's an implicit grab, use this actor */
   if (priv->implicit_grab_actor)
     actor = priv->implicit_grab_actor;
-- 
