From 370b2cf6d3e16c9d3900773d22c61c0209414257 Mon Sep 17 00:00:00 2001
From: Alessandro Astone <alessandro.astone@canonical.com>
Date: Tue, 26 May 2026 15:59:38 +0200
Subject: [PATCH 4/4] backend: Cleanup global cursor with an explicit setter

There is no use for the g_signal_accumulator_first_wins "override-cursor"
signal, so we can clean this up with an explicit setter in the backend instead.
---
 src/backends/meta-backend-private.h |  3 +++
 src/backends/meta-backend.c         | 27 +++++++++++++++++----------
 src/compositor/compositor.c         | 25 +++++--------------------
 3 files changed, 25 insertions(+), 30 deletions(-)

diff --git a/src/backends/meta-backend-private.h b/src/backends/meta-backend-private.h
index 26032250ead..d8ab5fbafda 100644
--- a/src/backends/meta-backend-private.h
+++ b/src/backends/meta-backend-private.h
@@ -248,3 +248,6 @@ ClutterCursor * meta_backend_get_cursor (MetaBackend       *backend,
                                          ClutterCursorType  cursor_type);
 
 ClutterCursorType meta_backend_get_global_cursor_type (MetaBackend *backend);
+
+gboolean meta_backend_set_global_cursor_type (MetaBackend       *backend,
+                                              ClutterCursorType  cursor_type);
diff --git a/src/backends/meta-backend.c b/src/backends/meta-backend.c
index 93134b4851c..9aba2d973c5 100644
--- a/src/backends/meta-backend.c
+++ b/src/backends/meta-backend.c
@@ -120,7 +120,6 @@ enum
   LID_IS_CLOSED_CHANGED,
   GPU_ADDED,
   PREPARE_SHUTDOWN,
-  OVERRIDE_CURSOR,
   RESET_KEYMAP_DESCRIPTION,
   RESET_KEYMAP_LAYOUT_INDEX,
 
@@ -210,6 +209,7 @@ struct _MetaBackendPrivate
 
   MetaRenderdoc *renderdoc;
 
+  ClutterCursorType global_cursor;
   gboolean cursor_visible;
 };
 typedef struct _MetaBackendPrivate MetaBackendPrivate;
@@ -893,12 +893,6 @@ meta_backend_class_init (MetaBackendClass *klass)
                   0,
                   NULL, NULL, NULL,
                   G_TYPE_NONE, 0);
-  signals[OVERRIDE_CURSOR] =
-    g_signal_new ("override-cursor",
-                  G_TYPE_FROM_CLASS (klass),
-                  G_SIGNAL_RUN_LAST, 0,
-                  g_signal_accumulator_first_wins, NULL, NULL,
-                  CLUTTER_TYPE_CURSOR_TYPE, 0);
   signals[RESET_KEYMAP_DESCRIPTION] =
     g_signal_new ("reset-keymap-description",
                   G_TYPE_FROM_CLASS (klass),
@@ -1429,6 +1423,7 @@ meta_backend_init (MetaBackend *backend)
 {
   MetaBackendPrivate *priv = meta_backend_get_instance_private (backend);
 
+  priv->global_cursor = CLUTTER_CURSOR_INHERIT;
   priv->cursor_visible = TRUE;
 }
 
@@ -2175,8 +2170,20 @@ meta_backend_get_cursor (MetaBackend       *backend,
 ClutterCursorType
 meta_backend_get_global_cursor_type (MetaBackend *backend)
 {
-  ClutterCursorType global_cursor = CLUTTER_CURSOR_INHERIT;
+  MetaBackendPrivate *priv = meta_backend_get_instance_private (backend);
 
-  g_signal_emit (backend, signals[OVERRIDE_CURSOR], 0, &global_cursor);
-  return global_cursor;
+  return priv->global_cursor;
 }
+
+gboolean
+meta_backend_set_global_cursor_type (MetaBackend       *backend,
+                                     ClutterCursorType  cursor_type)
+{
+  MetaBackendPrivate *priv = meta_backend_get_instance_private (backend);
+
+  if (priv->global_cursor == cursor_type)
+    return FALSE;
+
+  priv->global_cursor = cursor_type;
+  return TRUE;
+}
\ No newline at end of file
diff --git a/src/compositor/compositor.c b/src/compositor/compositor.c
