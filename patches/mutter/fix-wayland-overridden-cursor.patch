From 29aedbedc6a3b9e514d32152e61a028da352b633 Mon Sep 17 00:00:00 2001
From: Alessandro Astone <alessandro.astone@canonical.com>
Date: Mon, 13 Apr 2026 18:58:48 +0200
Subject: [PATCH 3/4] backend: Always retrieve the requested cursor

Users of meta_backend_get_cursor expect to get the cursor matching the
requested cursor type, and not the potentially overridden global cursor.
Stop lying to the callers and always return what they asked for.

This matters in the following sequence:
* Create startup sequence
* Set global CLUTTER_CURSOR_WAIT
* Wayland surface gets pointer focus and requests cursor shape
-> We must now store the requested cursor without global overrides
-> The wayland pointer uses meta_backend_get_cursor so it must not lie
* New startup sequence completes
* Restore the previously requested cursor

Closes: https://gitlab.gnome.org/GNOME/mutter/-/issues/4726
---
 src/backends/meta-backend.c | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/src/backends/meta-backend.c b/src/backends/meta-backend.c
index 9e9ece8ced5..93134b4851c 100644
--- a/src/backends/meta-backend.c
+++ b/src/backends/meta-backend.c
@@ -2168,10 +2168,6 @@ meta_backend_get_cursor (MetaBackend       *backend,
                          ClutterCursorType  cursor_type)
 {
   MetaCursorTracker *cursor_tracker = meta_backend_get_cursor_tracker (backend);
-  ClutterCursorType global_cursor = meta_backend_get_global_cursor_type (backend);
-
-  if (global_cursor != CLUTTER_CURSOR_INHERIT)
-    cursor_type = global_cursor;
 
   return CLUTTER_CURSOR (meta_cursor_xcursor_get (cursor_type, cursor_tracker));
 }
-- 
