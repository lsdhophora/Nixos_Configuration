Don't apply startup-status in enable() — the layout.js patch in
gnome-shell already handles the startup behavior. Applying it
here would override the post-startup hasOverview restoration and
permanently disable the overview.

diff --git a/lib/Manager.js b/lib/Manager.js
index abc1234..def5678 100644
--- a/lib/Manager.js
+++ b/lib/Manager.js
@@ -534,7 +534,6 @@
         this.#applyWindowMaximizedOnCreate(false);
         this.#applyDashIconSize(false);
-        this.#applyStartupStatus(false);
         this.#applyWorkspacesInAppGrid(false);
         this.#applyNotificationBannerPosition(false);
         this.#applyWorkspaceSwitcherShouldShow(false);
