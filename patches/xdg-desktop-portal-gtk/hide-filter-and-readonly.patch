 static gboolean
+suppress_right_click_cb (GtkWidget *widget, GdkEventButton *event, gpointer data)
+{
+  return event->button == 3;
+}
+
+static void
+suppress_right_click_in_widget (GtkWidget *widget, gpointer data)
+{
+  if (GTK_IS_TREE_VIEW (widget))
+    {
+      guint signal_id = g_signal_lookup ("button-press-event",
+                                          GTK_TYPE_WIDGET);
+      g_signal_handlers_disconnect_matched (widget,
+                                            G_SIGNAL_MATCH_ID,
+                                            signal_id,
+                                            0, NULL, NULL, NULL);
+      g_signal_connect (widget, "button-press-event",
+                        G_CALLBACK (suppress_right_click_cb), NULL);
+    }
+  if (GTK_IS_CONTAINER (widget))
+    gtk_container_forall (GTK_CONTAINER (widget),
+                          suppress_right_click_in_widget, data);
+}
+
+static void
+hide_recent_recursive (GtkWidget *widget, gpointer data)
+{
+  if (GTK_IS_PLACES_SIDEBAR (widget))
+    {
+      gtk_places_sidebar_set_show_recent (GTK_PLACES_SIDEBAR (widget), FALSE);
+      return;
+    }
+  if (GTK_IS_CONTAINER (widget))
+    gtk_container_forall (GTK_CONTAINER (widget), hide_recent_recursive, data);
+}
