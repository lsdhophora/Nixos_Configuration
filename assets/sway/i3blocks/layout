#!/usr/bin/env bash
last=""
print_layout() {
    state=$(swaymsg -t get_tree | jq -r '.. | select(.focused? == true) | .floating')
    if [ "$state" = "auto_on" ] || [ "$state" = "user_on" ]; then
        echo "[F]"
        last="[F]"
        return
    fi
    layout=$(swaymsg -t get_tree | jq -r '
        [.. | select(.layout? and .layout != "none" and .layout != "output" and (. | .. | select(.focused? == true))) | .layout][-1]
    ')
    [ -z "$layout" ] || [ "$layout" = "null" ] && layout="$last"
    case "$layout" in
        tabbed)   icon="[T]" ;;
        stacking) icon="[S]" ;;
        splith)   icon="[H]" ;;
        splitv)   icon="[V]" ;;
        *)        icon="$last" ;;
    esac
    [ -z "$icon" ] && return
    echo "$icon"
    last="$icon"
}
print_layout
swaymsg -t SUBSCRIBE -m '["window","binding","mode"]' | while read -r; do
    print_layout
done
